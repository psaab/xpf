# Canonical Makefile cluster/test target for userspace dataplane validation.
# Source via: BPFRX_CLUSTER_ENV=test/incus/loss-userspace-cluster.env ./test/incus/cluster-setup.sh <cmd>

INCUS_REMOTE="loss"
VM0="xpf-userspace-fw0"
VM1="xpf-userspace-fw1"
LAN_HOST="cluster-userspace-host"
PROFILE="xpf-cluster-userspace"

# Isolated userspace cluster on loss:
# - WAN uses a distinct spare mlx0 VF pair
# - LAN uses a distinct VLAN from the primary loss cluster
VF_WAN_PCI=("0000:65:00.4" "0000:65:00.5")
VF_LAN_PCI=("0000:65:05.4" "0000:65:05.5")
SRIOV_PARENT="mlx0"
SRIOV_LAN_PARENT="mlx1"
VF_LAN_VLAN=3667

NET_MGMT="incusbr0"
NET_HEARTBEAT="bpu-hb0"
NET_FABRIC="bpu-fab0"
NET_CLAN=""

CLUSTER_CONF="docs/ha-cluster-userspace.conf"

LAN_ADDR="10.0.61.102/24"
LAN_GW="10.0.61.1"
LAN_HOST_IP="10.0.61.102"
LAN_VIP4="10.0.61.1"
LAN_VIP6="2001:559:8585:ef00::1"
WAN_GW4="172.16.50.1"
WAN_VIP4="172.16.50.6"
IPERF_TARGET4="172.16.100.200"
IPERF_TARGET6="2001:559:8585:100::200"
