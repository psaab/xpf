# Legacy remote cluster on "loss" host with Mellanox SR-IOV VFs.
# The canonical Makefile cluster targets now default to loss-userspace-cluster.env.
#
# Source via: BPFRX_CLUSTER_ENV=test/incus/loss-cluster.env ./test/incus/cluster-setup.sh <cmd>
#
# Topology:
#   xpf-fw0:  virtio(fxp0,em0,fab) + mlx0-vf0(WAN) + mlx1-vf0(LAN, VLAN 3666)
#   xpf-fw1:  virtio(fxp0,em0,fab) + mlx0-vf1(WAN) + mlx1-vf1(LAN, VLAN 3666)
#   cluster-lan-host: mlx1-vf2(LAN, VLAN 3666) via nictype=sriov
#
# VMs use PCI passthrough (nictype=sriov doesn't work for VMs).
# Container uses nictype=sriov.

INCUS_REMOTE="loss"
PROFILE="xpf-cluster-loss"

# SR-IOV: PCI addresses for VF passthrough to VMs
# mlx0 VFs for WAN (reth0): vf0→fw0, vf1→fw1
VF_WAN_PCI=("0000:65:00.2" "0000:65:00.3")
# mlx1 VFs for LAN (reth1): vf0→fw0, vf1→fw1
VF_LAN_PCI=("0000:65:04.2" "0000:65:04.3")

# SR-IOV parent for container LAN (nictype=sriov works for containers)
SRIOV_LAN_PARENT="mlx1"

# Host-level VF VLAN tag for LAN (untagged inside VM/container)
VF_LAN_VLAN=3666

# Network names on the remote (bridges created/managed by incus)
NET_MGMT="incusbr0"
NET_HEARTBEAT="em0br"
NET_FABRIC="xpf-fab-loss"

# No bridge-based cluster LAN — LAN is SR-IOV VF
NET_CLAN=""

# Config file for this cluster
CLUSTER_CONF="${PROJECT_ROOT}/docs/ha-cluster-loss.conf"
